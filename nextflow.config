/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    pacbio-hifi-variant-nextflow-pipeline — Nextflow Configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    This file controls how the pipeline runs — resource allocation, execution
    profiles, container settings, and process-level configuration.

    It does NOT contain pipeline logic. Logic lives in:
        workflows/pacbio_variant_workflow.nf
        modules/local/
        modules/docker/

    Profiles:
        local     — default, uses conda environment
        docker    — runs all processes in Docker containers
        test      — runs pipeline on synthetic test dataset

    Resource labels (used in modules):
        process_low     — lightweight tasks (indexing, QC reporting)
        process_medium  — moderate tasks (alignment, bcftools calling)
        process_high    — intensive tasks (clair3, deepvariant inference)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/


// -----------------------------------------------------------------------
// Default parameters
// These match the defaults declared in main.nf.
// Duplicated here so nextflow.config is self-documenting and can be
// used as a reference without opening main.nf.
// -----------------------------------------------------------------------
params {
    reads                 = null
    reference             = null
    sample                = null
    outdir                = "results"
    aligner               = "minimap2"
    snv_caller            = "bcftools"
    threads               = 4
    clair3_model          = null

    // Container image versions — update here to change across all modules
    pipeline_container    = "pacbio-hifi-pipeline:1.0"
    pbmm2_container       = "pacbio-hifi-pipeline:pbmm2"
    clair3_container      = "pacbio-hifi-clair3:1.0"
    deepvariant_container = "google/deepvariant:1.6.1"
}


// -----------------------------------------------------------------------
// Process defaults
// Applied to every process unless overridden by a label or profile.
//
// errorStrategy
//   'terminate' — stop the pipeline immediately on any process failure.
//   Other options: 'retry', 'ignore', 'finish'
//   terminate is appropriate for a variant calling pipeline where a
//   failed alignment or variant call should not silently propagate.
//
// maxRetries
//   Not used with terminate but declared for completeness.
//   Set to 1 if switching errorStrategy to 'retry'.
// -----------------------------------------------------------------------
process {
    errorStrategy = 'terminate'
    maxRetries    = 1

    // -----------------------------------------------------------------------
    // Resource labels
    // Modules declare 'label process_low/medium/high' and these blocks
    // assign the actual CPU and memory values.
    // Adjust these values based on your available hardware.
    // -----------------------------------------------------------------------

    withLabel: process_low {
        cpus   = 1
        memory = '1 GB'
        time   = '30m'
    }

    withLabel: process_medium {
        cpus   = 4
        memory = '8 GB'
        time   = '2h'
    }

    withLabel: process_high {
        cpus   = 8
        memory = '14 GB'
        time   = '12h'
    }
}


// -----------------------------------------------------------------------
// Execution profiles
// Selected with -profile <name> on the command line.
// Multiple profiles can be combined: -profile docker,test
// -----------------------------------------------------------------------
profiles {

    // -----------------------------------------------------------------------
    // local profile (default)
    // Uses the conda environment defined in environment.yml.
    // Each process activates its own conda environment automatically.
    // Suitable for development on Mac or Linux without Docker.
    // -----------------------------------------------------------------------
    local {
        process.executor = 'local'

        conda {
            // Enable conda environment management
            enabled    = true
            // Cache conda environments in the pipeline directory
            // so they are not recreated on every run
            cacheDir   = "${projectDir}/.conda_cache"
            // Use mamba for faster environment solving if available
            useMamba   = false
        }
    }

    // -----------------------------------------------------------------------
    // docker profile
    // Runs all processes inside Docker containers.
    // Container images are declared in each module via the container directive.
    // Required for: pbmm2, clair3, deepvariant
    // -----------------------------------------------------------------------
    docker {
        process.executor = 'local'

        docker {
            enabled      = true
            // Run containers as current user to avoid permission issues
            // with output files written by root inside the container
            runOptions   = "--user \$(id -u):\$(id -g)"
            // Use the host's /tmp as the temporary directory inside containers
            temp         = 'auto'
        }
    }

    // -----------------------------------------------------------------------
    // test profile
    // Runs the pipeline on the provided synthetic chr20 test dataset.
    // Combines with local or docker: -profile docker,test
    //
    // Usage:
    //   nextflow run main.nf -profile test
    //   nextflow run main.nf -profile docker,test
    // -----------------------------------------------------------------------
    test {
        params {
            reads     = "${projectDir}/test_data/synthetic_reads.fastq"
            reference = "${projectDir}/reference/chr20.fa"
            sample    = "synthetic_reads"
            outdir    = "test_results"
        }

        // Reduce resource requirements for test runs
        process {
            withLabel: process_low {
                cpus   = 1
                memory = '1 GB'
            }
            withLabel: process_medium {
                cpus   = 2
                memory = '4 GB'
            }
            withLabel: process_high {
                cpus   = 2
                memory = '8 GB'
            }
        }
    }
}


// -----------------------------------------------------------------------
// Nextflow execution report settings
// Automatically generates HTML reports after each pipeline run.
//
// timeline — shows how long each process took
// report   — detailed execution report with resource usage
// dag      — visualizes the pipeline DAG as an SVG
//
// These are written to the results directory and are useful for
// debugging, optimizing resource usage, and documenting runs.
// -----------------------------------------------------------------------
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.svg"
    overwrite = true
}


// -----------------------------------------------------------------------
// Manifest
// Pipeline metadata — displayed in Nextflow logs and used by nf-core
// tooling if this pipeline is ever submitted to nf-core.
// -----------------------------------------------------------------------
manifest {
    name            = 'pacbio-hifi-variant-nextflow-pipeline'
    author          = 'Muhammad Faizan Khalid'
    description     = 'Nextflow pipeline for PacBio HiFi variant calling'
    version         = '1.0.0'
    nextflowVersion = '>=24.10'
    mainScript      = 'main.nf'
}
